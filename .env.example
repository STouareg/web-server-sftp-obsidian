TZ=Europe/Kyiv
SFTP_HOST=192.168.1.10
SFTP_PORT=22
SFTP_USER=your_sftp_user
SFTP_PASSWORD=your_sftp_password
# Remote path and local copy path (basename drives page title and messages)
SFTP_REMOTE_FILE=/path/on/server/Sk_sermons_actual.md
LOCAL_FILE=/data/Sk_sermons_actual.md
# Optional: exact browser tab title (otherwise derived from LOCAL_FILE, e.g. "Sk sermons actual")
# PAGE_TITLE=Sermons
CHECK_INTERVAL_SECONDS=300
