TZ=Europe/Kyiv
SFTP_HOST=192.168.1.10
SFTP_PORT=22
SFTP_USER=your_sftp_user
SFTP_PASSWORD=your_sftp_password
# Remote path and local copy path (basename drives page title and messages)
SFTP_REMOTE_FILE=/path/on/server/Sk_sermons_actual.md
LOCAL_FILE=/data/Sk_sermons_actual.md
# Optional: exact browser tab title (otherwise derived from LOCAL_FILE, e.g. "Sk sermons actual")
# PAGE_TITLE=Sermons
# Footer under the note on / (default "All rights reserved." if unset). Set to empty string to remove footer.
# PAGE_FOOTER=© 2026
# Optional: header logo + favicon URL (built-in default SVG if unset). Set LOGO_URL= empty to hide.
# LOGO_URL=
# URL when clicking the logo (default skinia.com.ua; new tab). Empty = logo points to / only.
# LOGO_LINK_URL=https://www.skinia.com.ua/
# Optional extra text under the logo (omit for image-only).
# LOGO_LINK_TEXT=
CHECK_INTERVAL_SECONDS=300
# Optional: Telegram alerts on SFTP/config errors (Bot API). Omit both to disable.
# TELEGRAM_BOT_TOKEN=123456789:AA...
# TELEGRAM_CHAT_ID=-1001234567890
# TELEGRAM_ERROR_COOLDOWN_SECONDS=1800
